programa {
inteiro numero
logico resultado 

  funcao inicio() {
    /*Programa que le um numero e mostra se é par ou ímpar*/
    //Declarar variaveis
escreva("Digite um numero:") 
leia(numero)
//Processamento
se(numero%2==0)
    resultado = verdadeiro
    senao 
    resultado=falso
  
    se(resultado == verdadeiro)
    escreva("Par")
    senao 
    escreva("Impar")
    
  }
}
